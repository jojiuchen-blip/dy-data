COMPOSE_PROJECT_NAME=dy-dashboard

# Public entrypoint. Keep raw service ports unpublished; expose only proxy.
HTTP_BIND=127.0.0.1
HTTP_PORT=8080

POSTGRES_DB=dy_dashboard
POSTGRES_USER=dy_dashboard
POSTGRES_PASSWORD=CHANGE_ME_POSTGRES_PASSWORD
DATABASE_URL=postgresql+psycopg://dy_dashboard:CHANGE_ME_POSTGRES_PASSWORD@postgres:5432/dy_dashboard

API_IMAGE=dy-dashboard-api:local
WORKER_IMAGE=dy-dashboard-worker:local
WEB_IMAGE=dy-dashboard-web:local
BROWSER_IMAGE=dy-dashboard-browser:local
API_UPSTREAM=http://api:8000

DY_SUPER_ADMIN_USERNAME=CHANGE_ME_SUPER_ADMIN_USERNAME
DY_SUPER_ADMIN_PASSWORD_HASH=CHANGE_ME_SUPER_ADMIN_PASSWORD_HASH
DY_SESSION_SECRET=CHANGE_ME_SESSION_SECRET
DY_SESSION_COOKIE_SECURE=true
DY_WEB_BASE_URL=https://dy-business-engine.com
DY_AGENT_ENVIRONMENT=test
UVICORN_HOST=0.0.0.0

DOUYIN_APP_ID=CHANGE_ME_DOUYIN_APP_ID
DOUYIN_APP_SECRET=CHANGE_ME_DOUYIN_APP_SECRET
DOUYIN_ACCOUNT_ID=CHANGE_ME_DOUYIN_ACCOUNT_ID

BROWSER_VNC_PASSWORD=CHANGE_ME_BROWSER_VNC_PASSWORD
CHROMIUM_START_URL=https://life.douyin.com/
BROWSER_CDP_URL=http://browser:9222
BROWSER_EXPORT_DOWNLOAD_DIR=/home/browser/Downloads/job-runs
BROWSER_EXPORT_ARTIFACT_DIR=/data/browser-exports
BROWSER_SCREEN_WIDTH=1440
BROWSER_SCREEN_HEIGHT=1000

WORKER_COMMAND=python -m apps.worker.scheduler
