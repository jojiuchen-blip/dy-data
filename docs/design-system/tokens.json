{
  "meta": {
    "name": "dy-data UI Design System",
    "version": "0.1.0",
    "status": "draft",
    "lastUpdated": "2026-06-25",
    "language": "zh-CN",
    "colorMode": "light-only",
    "darkModeStatus": "not-supported-in-v0.1",
    "sourceOfTruth": "docs/design-system/tokens.json",
    "currentImplementationSource": "apps/web/src/styles.css",
    "purpose": "Provide a visible and machine-readable baseline for dy-data product UI decisions."
  },
  "principles": [
    {
      "name": "运营后台优先",
      "description": "界面服务高频筛选、比对、跟进和审核，不做营销页式装饰。"
    },
    {
      "name": "轻量 token 先行",
      "description": "先固化颜色、字号、间距、半径、控件高度、层级和关键组件规则，再逐步迁移页面。"
    },
    {
      "name": "可视化决策",
      "description": "重要规范值必须能在 HTML 预览里被人类直接看到，而不是只存在于文字清单。"
    },
    {
      "name": "浅色模式优先",
      "description": "V0.1 只固化浅色模式；暗色模式不跟随系统设置，也不作为当前设计系统承诺。"
    },
    {
      "name": "规范需要校验",
      "description": "关键 token 与已实现 CSS 通过测试绑定，后续再扩展到 lint、视觉回归和 PR checklist。"
    }
  ],
