    },
    "mobileShell": {
      "structure": [
        "top secondary subnav",
        "page frame",
        "collapsible filters",
        "record cards",
        "bottom primary navigation"
      ],
      "rule": "Mobile uses bottom first-level navigation and top second-level navigation."
    },
    "listPage": {
      "structure": [
        "H1",
        "realtime badge",
        "filters",
        "result summary",
        "table or cards",
        "pagination"
      ],
      "rule": "List pages should keep the same scan order across settlement, clues, orders and admin lists."
    }
