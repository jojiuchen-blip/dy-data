          "buttons",
          "settings",
          "logout",
          "detail links"
        ],
        "emphasisUseCases": [
          "active mobile primary navigation",
          "primary rail active entry",
          "brand or module entry"
        ],
        "namingRule": "Register semantic names in SolarIcon.tsx; split normal and emphasis states explicitly, such as cluesLine and clues.",
        "semanticExamples": {
          "show": "eye linear",
          "hide": "eye closed or slash linear",
          "copy": "copy linear",
          "detail": "document or receipt linear",
          "filter": "filter linear",
          "collapse": "alt arrow up linear",
          "settings": "settings linear",
          "logout": "logout linear unless used as a highlighted module action",
          "dashboard": "chart linear",
          "clues": "chat round dots bold-duotone only when active",
          "admin": "shield bold-duotone only when active"
